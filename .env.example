#################################################
# Application
#################################################

# development | production
NODE_ENV=development

# Port the Express server listens on
PORT=8080

# Public base URL of this deployment (no trailing slash).
# Used to build PayU success/failure redirect URLs.
BASE_URL=http://localhost:8080

#################################################
# Database
#################################################

# MongoDB connection string (used for both app data and session store)
DB_URL=mongodb://127.0.0.1:27017/bharatFootwear

#################################################
# Sessions
#################################################

# Secret used to sign session cookies and encrypt the Mongo session store.
# Must be at least 8 characters with 2+ uppercase, 2+ lowercase, 2+ numbers,
# and 2+ special characters (e.g. Sample#Secret99!), or session storage fails.
SECRET=your-session-secret

#################################################
# Cloudinary (image storage)
#################################################

CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

#################################################
# PayU (payment gateway)
#################################################

PAYU_API_KEY=your-payu-key
PAYU_SALT=your-payu-256bit-salt

# TEST | LIVE
PAYU_MODE=TEST

#################################################
# Maps (TomTom)
#################################################

MAP_TOKEN=your-tomtom-maps-api-key
