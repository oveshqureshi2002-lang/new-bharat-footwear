<%- layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/profile.css">

<body>
    <div class="main-container mt-4 mb-4" style="max-width: 560px; margin-left: auto; margin-right: auto;">
        <a class="edit-form-back" href="/profile/<%= currUser._id %>"><i class="fa-solid fa-arrow-left"></i> Back to Profile</a>
        <h3>Update Profile</h3>
        <div class="form">
            <form action="/profile/<%= currUser._id %>" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="" class="form-label">Full Name</label>
                    <input type="text" class="form-control" name="name" value="<%= user.name %>" required>
                    <div class="invalid-feedback">Please add your full name.</div>
                </div>
                <div class="mb-3">
                    <label for="" class="form-label">Profile image</label>
                    <input type="file" class="form-control" name="image">
                    <div class="form-hint">Leave empty to keep your current photo.</div>
                </div>
                <div class="mb-3">
                    <label for="" class="form-label">Email</label>
                    <input type="text" class="form-control" name="email" value="<%= user.email %>" required>
                    <div class="invalid-feedback">Please add a valid email.</div>
                </div>
                <div class="mb-3">
                    <label for="" class="form-label">Mobile</label>
                    <input type="text" class="form-control" name="contact" value="<%= user.contact %>" required>
                    <div class="invalid-feedback">Please add your mobile number.</div>
                </div>
                <div class="mb-3">
                    <label for="" class="form-label">Address</label>
                    <input type="text" class="form-control" name="address" value="<%= user.address %>" required>
                    <div class="invalid-feedback">Please add your address.</div>
                </div>
                <div class="form-actions">
                    <a class="btn-secondary" href="/profile/<%= currUser._id %>">Cancel</a>
                    <input type="submit" class="btn btn-primary" value="Update">
                </div>
            </form>
        </div>
    </div>
</body>