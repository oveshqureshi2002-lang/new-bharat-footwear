<h1>All users</h1>

<% if(userList.length) { %>
    <div class="list-container mt-2">
        <table class="table table-striped">
            <thead class="table-primary">
                <tr>
                    <th>User</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody style="text-align: start;">
                <% for(user of userList) { %>
                    <tr>
                        <td>
                            <div class="user-chip">
                                <span class="avatar"><%= (user.name || user.username || '?').charAt(0) %></span>
                                <span><%= user.name %></span>
                            </div>
                        </td>
                        <td><%= user.contact %></td>
                        <td><%= user.email %></td>
                        <td>
                            <% if(user.role === 'admin') { %>
                                <span class="admin-badge info">ADMIN</span>
                            <% } else { %>
                                <span class="admin-badge neutral"><%= user.role.toUpperCase() %></span>
                            <% } %>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="admin-empty">
        <i class="fa-solid fa-users"></i>
        <h5>No users yet</h5>
        <p>Registered customers will show up here.</p>
    </div>
<% } %>