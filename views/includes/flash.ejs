
<% if(success.length) { %>
    <div class="alert alert-info alert-dismissible fade show col-6 offset-3 mt-2" role="alert">
        <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>
<% if(error.length) { %>
    <div class="alert alert-warning alert-dismissible fade show col-6 offset-3 mt-2" role="alert">
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

